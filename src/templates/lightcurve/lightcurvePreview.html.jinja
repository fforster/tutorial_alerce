{#
  Light curve panel — rendered by /htmx/lightcurve.
  Expects `lc` = {"survey": str, "bands": [{"name": str, "points": [{mjd, flux, e_flux, candid}]}], "n_det": int}.
  We inline the JSON payload on a data-* attribute; lightcurve.js reads it
  and calls Chart.js. The canvas id is unique per object so htmx swaps work.
#}
<div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4">
  <div class="tw-flex tw-items-center tw-justify-between tw-mb-2 tw-gap-3">
    <div class="tw-text-text-secondary tw-text-xs tw-uppercase">Light curve</div>
    <div class="tw-flex tw-items-center tw-gap-3">
      <div class="tw-text-text-muted tw-text-xs">
        {{ lc.n_det }} detection{% if lc.n_det != 1 %}s{% endif %}
        {% if lc.n_fp %}· {{ lc.n_fp }} FP{% endif %}
        · {{ lc.bands|length }} band{% if lc.bands|length != 1 %}s{% endif %}
      </div>
      {% if lc.n_det > 0 or (lc.n_fp or 0) > 0 %}
        {#
          Flux/Mag toggle is a pure client-side projection: points arrive in
          nJy and lightcurve.js applies the AB-ZP-31.4 conversion when Mag is
          selected. No server round trip.
        #}
        <div
          class="lc-mode-toggle tw-inline-flex tw-rounded tw-border tw-border-border tw-overflow-hidden tw-text-xs"
          data-target="lc-canvas-{{ oid }}"
        >
          <button
            type="button"
            class="lc-mode-btn tw-px-2 tw-py-0.5 tw-bg-bg-secondary tw-text-text-primary"
            data-lc-mode="flux"
            aria-pressed="true"
          >Flux</button>
          <button
            type="button"
            class="lc-mode-btn tw-px-2 tw-py-0.5 tw-bg-bg-card tw-text-text-muted"
            data-lc-mode="mag"
            aria-pressed="false"
          >Mag</button>
        </div>
      {% endif %}
    </div>
  </div>

  {% if lc.n_det > 0 or (lc.n_fp or 0) > 0 %}
    <div class="tw-relative tw-h-72">
      <canvas
        id="lc-canvas-{{ oid }}"
        class="lightcurve-canvas"
        data-lc='{{ lc|tojson_compact }}'
      ></canvas>
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">No detections to plot.</div>
  {% endif %}
</div>
