{#
  Light curve panel — rendered by /htmx/lightcurve.
  Expects `lc` = {"survey": str, "bands": [{"name": str, "points": [{mjd, flux, e_flux, candid}]}], "n_det": int}.
  We inline the JSON payload on a data-* attribute; lightcurve.js reads it
  and calls Chart.js. The canvas id is unique per object so htmx swaps work.
#}
<div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4">
  <div class="tw-flex tw-items-center tw-justify-between tw-mb-2 tw-gap-3">
    <div
      class="tw-text-text-secondary tw-text-xs tw-uppercase"
      title="Zoom: scroll wheel. Box-zoom: shift+drag. Pan: ctrl+drag. Reset: double-click."
    >Light curve</div>
    <div class="tw-flex tw-items-center tw-gap-3">
      {% if lc.n_det > 0 or (lc.n_fp or 0) > 0 %}
        {#
          Diff/Sci and Flux/Mag toggles are both pure client-side projections:
          points arrive with both flux values (diff + optional sci) and the JS
          picks which to plot + whether to apply the AB-ZP-31.4 mag transform.
          No server round trip.
        #}
        {#
          Cycle-buttons: one button per axis of state, showing only the
          currently active value. Click cycles to the next option; the
          button's `data-lc-*` attribute is the source of truth that the
          JS binder reads on each click.
        #}
        {% if lc.has_science_flux %}
          <button
            type="button"
            class="lc-source-toggle tw-px-2 tw-py-0.5 tw-text-xs tw-border tw-border-border tw-rounded tw-bg-bg-secondary tw-text-text-primary hover:tw-bg-bg-tertiary"
            data-target="lc-canvas-{{ oid }}"
            data-lc-source="diff"
            title="Click to toggle Diff ↔ Sci flux. Difference flux is from the subtracted image; science flux is the total on the science image (when a reference source exists)."
          >Diff</button>
        {% endif %}
        <button
          type="button"
          class="lc-mode-toggle tw-px-2 tw-py-0.5 tw-text-xs tw-border tw-border-border tw-rounded tw-bg-bg-secondary tw-text-text-primary hover:tw-bg-bg-tertiary"
          data-target="lc-canvas-{{ oid }}"
          data-lc-mode="flux"
          title="Click to toggle linear flux (nJy) ↔ AB magnitude (ZP 31.4, reversed axis)."
        >Flux</button>
        <button
          type="button"
          class="lc-abs-toggle tw-px-2 tw-py-0.5 tw-text-xs tw-border tw-border-border tw-rounded tw-bg-bg-secondary tw-text-text-primary hover:tw-bg-bg-tertiary"
          data-target="lc-canvas-{{ oid }}"
          data-lc-abs="app"
          title="Click to toggle Apparent ↔ Absolute (rest-frame @10 pc, via Planck-2018 distance modulus). Requires positive z."
        >App</button>
        <label
          class="tw-inline-flex tw-items-center tw-gap-1 tw-text-xs tw-text-text-muted"
          title="Host-galaxy spectroscopic redshift. Click a source in the sky view to populate this from a VizieR catalog, or type one in."
        >
          z
          <input
            id="lc-redshift-{{ oid }}"
            type="number"
            step="any"
            min="0"
            placeholder="z"
            data-target="lc-canvas-{{ oid }}"
            class="lc-redshift-input tw-w-20 tw-px-1.5 tw-py-0.5 tw-bg-bg-secondary tw-border tw-border-border tw-rounded tw-text-text-primary tw-font-mono"
          />
        </label>
        <button
          type="button"
          class="lc-dered-toggle tw-px-2 tw-py-0.5 tw-text-xs tw-border tw-border-border tw-rounded tw-bg-bg-secondary tw-text-text-primary hover:tw-bg-bg-tertiary"
          data-target="lc-canvas-{{ oid }}"
          data-lc-dered="obs"
          title="Click to toggle Observed ↔ Dereddened (Fitzpatrick 1999 Milky-Way extinction, A_λ = R_λ × E(B-V) per band). Requires a positive E(B-V)."
        >Obs</button>
        <label
          class="tw-inline-flex tw-items-center tw-gap-1 tw-text-xs tw-text-text-muted"
          title="Milky-Way E(B-V) from the IRSA dust proxy (SF11 preferred, SFD98 fallback), cached per RA/Dec rounded to 0.01°. Leave empty for auto, or type in to override."
        >
          E(B-V)
          <input
            id="lc-ebv-{{ oid }}"
            type="number"
            step="any"
            min="0"
            placeholder="auto"
            data-target="lc-canvas-{{ oid }}"
            class="lc-ebv-input tw-w-20 tw-px-1.5 tw-py-0.5 tw-bg-bg-secondary tw-border tw-border-border tw-rounded tw-text-text-primary tw-font-mono"
          />
        </label>
        <button
          type="button"
          class="chart-zoom-reset-btn tw-px-2 tw-py-0.5 tw-text-xs tw-border tw-border-border tw-rounded tw-bg-bg-card tw-text-text-muted hover:tw-text-text-primary"
          data-target="lc-canvas-{{ oid }}"
          title="Reset the light-curve zoom (same as double-clicking the chart)."
        >Reset zoom</button>
      {% endif %}
    </div>
  </div>

  {% if lc.n_det > 0 or (lc.n_fp or 0) > 0 %}
    <div class="tw-relative tw-h-72">
      <canvas
        id="lc-canvas-{{ oid }}"
        class="lightcurve-canvas"
        data-lc='{{ lc|tojson_compact }}'
        {% if ra is not none %}data-ra="{{ ra }}"{% endif %}
        {% if dec is not none %}data-dec="{{ dec }}"{% endif %}
        data-ext-r='{{ extinction_r|tojson_compact }}'
      ></canvas>
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">No detections to plot.</div>
  {% endif %}
</div>
