{#
  Light curve panel — rendered by /htmx/lightcurve.
  Expects `lc` = {"survey": str, "bands": [{"name": str, "points": [{mjd, flux, e_flux, candid}]}], "n_det": int}.
  We inline the JSON payload on a data-* attribute; lightcurve.js reads it
  and calls Chart.js. The canvas id is unique per object so htmx swaps work.
#}
<div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4">
  <div class="tw-flex tw-items-center tw-justify-between tw-mb-2 tw-gap-3">
    <div class="tw-text-text-secondary tw-text-xs tw-uppercase">Light curve</div>
    <div class="tw-flex tw-items-center tw-gap-3">
      <div class="tw-text-text-muted tw-text-xs">
        {{ lc.n_det }} detection{% if lc.n_det != 1 %}s{% endif %}
        {% if lc.n_fp %}· {{ lc.n_fp }} FP{% endif %}
        · {{ lc.bands|length }} band{% if lc.bands|length != 1 %}s{% endif %}
      </div>
      {% if lc.n_det > 0 or (lc.n_fp or 0) > 0 %}
        {#
          Diff/Sci and Flux/Mag toggles are both pure client-side projections:
          points arrive with both flux values (diff + optional sci) and the JS
          picks which to plot + whether to apply the AB-ZP-31.4 mag transform.
          No server round trip.
        #}
        {% if lc.has_science_flux %}
          <div
            class="lc-source-toggle tw-inline-flex tw-rounded tw-border tw-border-border tw-overflow-hidden tw-text-xs"
            data-target="lc-canvas-{{ oid }}"
            title="Difference flux is measured on the subtracted image (source − reference). Science flux is the total flux on the science image, only available when a reference source exists; transients without a host may have no science-flux points."
          >
            <button
              type="button"
              class="lc-source-btn tw-px-2 tw-py-0.5 tw-bg-bg-secondary tw-text-text-primary"
              data-lc-source="diff"
              aria-pressed="true"
              title="Difference flux: psf flux measured on the difference (science − reference) image."
            >Diff</button>
            <button
              type="button"
              class="lc-source-btn tw-px-2 tw-py-0.5 tw-bg-bg-card tw-text-text-muted"
              data-lc-source="sci"
              aria-pressed="false"
              title="Science (total) flux on the science image. Derived from mag_corr for ZTF and scienceFlux for LSST; blank for points without an associated reference source (often the case for pure transients)."
            >Sci</button>
          </div>
        {% endif %}
        <div
          class="lc-mode-toggle tw-inline-flex tw-rounded tw-border tw-border-border tw-overflow-hidden tw-text-xs"
          data-target="lc-canvas-{{ oid }}"
          title="Switch the Y-axis between linear flux (nJy) and AB magnitude (zero point 31.4, reversed axis so brighter is up)."
        >
          <button
            type="button"
            class="lc-mode-btn tw-px-2 tw-py-0.5 tw-bg-bg-secondary tw-text-text-primary"
            data-lc-mode="flux"
            aria-pressed="true"
            title="Linear flux in nanojansky."
          >Flux</button>
          <button
            type="button"
            class="lc-mode-btn tw-px-2 tw-py-0.5 tw-bg-bg-card tw-text-text-muted"
            data-lc-mode="mag"
            aria-pressed="false"
            title="AB magnitude (ZP 31.4). Points with flux ≤ 0 are dropped."
          >Mag</button>
        </div>
      {% endif %}
    </div>
  </div>

  {% if lc.n_det > 0 or (lc.n_fp or 0) > 0 %}
    <div class="tw-relative tw-h-72">
      <canvas
        id="lc-canvas-{{ oid }}"
        class="lightcurve-canvas"
        data-lc='{{ lc|tojson_compact }}'
      ></canvas>
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">No detections to plot.</div>
  {% endif %}
</div>
