{#
  Deferred FP fragment — returned by /htmx/lc_fp.

  Replaces the loading-strip span via hx-swap="outerHTML". On success we
  hand the freshly-shaped LC bundle (detections re-merged with v2 mag_corr
  + FP bands) to `lcSetBundle` so the chart rebuilds in place. On failure
  we still consume the placeholder so the spinner stops.
#}
{% if bundle %}
<span class="tw-text-text-muted">FP&nbsp;✓</span>
<script>
(function () {
  if (window.lcSetBundle) {
    window.lcSetBundle("lc-canvas-{{ oid }}", {{ bundle|tojson_compact|safe }});
  }
})();
</script>
{% else %}
<span class="tw-text-text-muted" title="No forced photometry available for this object.">FP&nbsp;—</span>
{% endif %}
