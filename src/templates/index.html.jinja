{% extends "base.html.jinja" %}

{% block body %}
<div class="tw-flex tw-flex-col tw-h-full">

  <header class="tw-h-12 tw-bg-bg-secondary tw-border-b tw-border-border tw-flex tw-items-center tw-px-4 tw-gap-3">
    {#
      Brand link. Plain `<a href="/">` does a full-page reload to the
      empty home: the form re-fetches its defaults via /htmx/search_objects
      and the results slot falls back to the empty-hint template, so any
      filters / pagination / detail state are wiped — the simplest "reset
      everything" gesture without us having to mirror the reset logic in
      JS. Logo SVG is the ALeRCE eagle from the prototype, white-fill so it
      reads on the dark header.
    #}
    <a
      href="/"
      class="tw-flex tw-items-center tw-gap-2 tw-text-accent tw-font-bold tw-text-sm tw-flex-none hover:tw-text-text-primary"
      title="Back to home (clears all filters)"
      aria-label="ALeRCE Explorer — back to home"
    >
      <img
        src="/static/img/alerce-logo.svg"
        alt=""
        class="tw-h-[34px] tw-w-[34px] tw-flex-none"
      />
      <span>ALeRCE <span class="tw-text-text-secondary tw-font-normal tw-text-xs">tutorial · htmx</span></span>
    </a>
    {#
      Detail-only nav row, lifted into the global header so the detail
      panels reclaim the row below for actual data. Hidden on the listing
      and any other empty state — `object_nav.js::updateButtons` toggles
      `tw-hidden` ↔ `tw-flex` based on whether a detail is on screen
      (`#object-detail` carries the current OID). The back button targets
      `backToResults()` (helpers.js, URL-derived) and the prev/next arrows
      target `navObject(...)` (object_nav.js).
    #}
    <div
      id="detail-nav-bar"
      class="tw-hidden tw-items-center tw-gap-2 tw-flex-1 tw-min-w-0"
    >
      <button
        type="button"
        class="tw-px-3 tw-py-1 tw-text-xs tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded tw-flex-none"
        onclick="backToResults()"
      >← Back to results</button>
      {#
        Page-of-OIDs dot row — populated by object_nav.js from
        window._resultsNav. Each OID becomes a 9×9 dot: filled accent for
        the current OID, hollow ring for the rest. `justify-between` lets
        the row grow into the header's free space; `flex-1` claims that
        space from the surrounding controls.
      #}
      <div
        id="object-nav-list"
        class="tw-flex tw-items-center tw-justify-between tw-gap-1 tw-min-w-0 tw-flex-1 tw-px-2 tw-whitespace-nowrap"
      ></div>
      {#
        Prev/next arrows + position indicator. Hidden by default; the JS
        reveals them iff a results-page nav state exists, so a deep-link
        without context just shows the back button + dots (which will
        also be empty without nav state).
      #}
      <div id="object-nav" class="tw-hidden tw-items-center tw-gap-2 tw-flex-none">
        <button
          type="button"
          id="object-nav-prev"
          class="tw-px-2 tw-py-1 tw-text-sm tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
          title="Previous object (←)"
          onclick="navObject('prev')"
        >←</button>
        <span id="object-nav-position" class="tw-text-xs tw-text-text-muted mono"></span>
        <button
          type="button"
          id="object-nav-next"
          class="tw-px-2 tw-py-1 tw-text-sm tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
          title="Next object (→)"
          onclick="navObject('next')"
        >→</button>
      </div>
    </div>
    <div class="tw-ml-auto tw-text-xs tw-text-text-muted tw-flex-none">Slice 1 scaffold</div>
  </header>

  <div class="tw-flex tw-flex-1 tw-min-h-0">

    {#
      Every filter param flows through `filter_qs` so the initial search-form,
      listing, and detail `hx-get`s all pre-load with the same state that's in
      the URL. Empty/default values are dropped to match `_share_url`'s output
      exactly (no asymmetric /?… ↔ hydration drift). Defined once with `set`
      so extending the filter list means editing one place, not three.
    #}
    {%- set filter_qs %}
      {%- if initial_classifier %}&classifier={{ initial_classifier|urlencode }}{% endif %}
      {%- if initial_classifier_version %}&classifier_version={{ initial_classifier_version|urlencode }}{% endif %}
      {%- if initial_class_name %}&class_name={{ initial_class_name|urlencode }}{% endif %}
      {%- if initial_probability and initial_probability > 0 %}&probability={{ initial_probability }}{% endif %}
      {%- if initial_n_det_min is not none %}&n_det_min={{ initial_n_det_min }}{% endif %}
      {%- if initial_n_det_max is not none %}&n_det_max={{ initial_n_det_max }}{% endif %}
      {%- if initial_firstmjd_min is not none %}&firstmjd_min={{ initial_firstmjd_min }}{% endif %}
      {%- if initial_firstmjd_max is not none %}&firstmjd_max={{ initial_firstmjd_max }}{% endif %}
      {%- if initial_ra is not none and initial_dec is not none %}&ra={{ initial_ra }}&dec={{ initial_dec }}{% if initial_radius is not none %}&radius={{ initial_radius }}{% endif %}{% endif %}
      {%- if initial_oids %}&oids={{ initial_oids|urlencode }}{% endif %}
      {%- if initial_page and initial_page > 1 %}&page={{ initial_page }}{% endif %}
    {%- endset %}

    <aside id="search-panel" class="tw-w-80 tw-flex-shrink-0 tw-bg-bg-secondary tw-border-r tw-border-border tw-overflow-y-auto">
      <div
        id="search-form-slot"
        hx-get="{{ API_URL }}/htmx/search_objects/?survey={{ initial_survey }}{{ filter_qs|trim }}"
        hx-trigger="load"
        hx-swap="innerHTML"
      ></div>
    </aside>

    {# Collapse handle — zero-width spacer with an absolutely-positioned button
       straddling the sidebar's right edge, centered vertically. Stays in place
       when the sidebar collapses (the spacer shifts left with the flex row),
       so users always have a hit target to reopen the panel. #}
    <div class="tw-relative tw-w-0 tw-flex-shrink-0 tw-z-20">
      <button
        type="button"
        id="search-panel-toggle"
        class="tw-absolute tw-top-1/2 tw-left-0 tw--translate-x-2 tw--translate-y-1/2 tw-w-7 tw-h-16 tw-flex tw-items-center tw-justify-center tw-rounded tw-border tw-border-border tw-bg-bg-card tw-text-text-muted hover:tw-text-text-primary tw-text-sm tw-shadow"
        title="Hide the search panel"
        aria-controls="search-panel"
        aria-expanded="true"
      >&laquo;</button>
    </div>

    <main class="tw-flex-1 tw-overflow-auto tw-p-4">
      {#
        Deep-link hydration: `?oid=…` jumps straight to the object detail
        (filter params tag along as passthrough so the detail view can echo
        them into HX-Push-Url); any filter param (without oid) pre-runs the
        listing; fresh `/` keeps the empty-hint default.
      #}
      {% if initial_oid %}
        <div
          id="results-slot"
          hx-get="{{ API_URL }}/htmx/detail?oid={{ initial_oid|urlencode }}&survey_id={{ initial_survey }}{{ filter_qs|trim }}{% if initial_identifier %}&identifier={{ initial_identifier|urlencode }}{% endif %}"
          hx-trigger="load"
          hx-swap="innerHTML"
        ></div>
      {% elif initial_classifier or initial_classifier_version or initial_class_name or initial_probability or initial_n_det_min is not none or initial_n_det_max is not none or initial_firstmjd_min is not none or initial_firstmjd_max is not none or (initial_ra is not none and initial_dec is not none) or initial_oids or initial_page %}
        <div
          id="results-slot"
          hx-get="{{ API_URL }}/htmx/list_objects?survey={{ initial_survey }}{{ filter_qs|trim }}"
          hx-trigger="load"
          hx-swap="innerHTML"
        ></div>
      {% else %}
        <div
          id="results-slot"
          hx-get="{{ API_URL }}/htmx/list_objects"
          hx-trigger="load"
          hx-swap="innerHTML"
        ></div>
      {% endif %}
    </main>

  </div>
</div>
<script>
  (function () {
    const btn = document.getElementById("search-panel-toggle");
    const panel = document.getElementById("search-panel");
    if (!btn || !panel) return;
    // Expose the setter so helpers.js can auto-hide on drill-in / auto-show on
    // Back — the toggle button's aria/text/title stay in sync either way.
    window.setSearchPanelVisible = (visible) => {
      panel.classList.toggle("tw-hidden", !visible);
      btn.setAttribute("aria-expanded", visible ? "true" : "false");
      btn.textContent = visible ? "\u00ab" : "\u00bb";
      btn.title = visible ? "Hide the search panel" : "Show the search panel";
    };
    btn.addEventListener("click", () => {
      window.setSearchPanelVisible(panel.classList.contains("tw-hidden"));
    });
  })();
</script>
{% endblock %}
