{#
  Stamp viewer panel — rendered by /htmx/stamps.

  Contract: ctx has {detections, selected, stamp_types, stamp_urls,
  stamp_url_templates}.
  - `detections` is the picker list (identifier, mjd, band) sorted MJD DESC.
  - `selected` is the currently chosen entry; `stamp_urls` has the initial
    URL per stamp type.
  - `stamp_url_templates` has the same URLs with __IDENT__ in place of the
    identifier; the client swaps that placeholder to repoint the canvases
    at a different detection without another server round trip.

  Detection changes (picker onchange OR a light-curve chart click) are
  handled entirely in stamps.js via window.updateStampsForIdentifier(id),
  so only the initial panel load hits this endpoint.
#}
<div
  id="stamps-panel"
  class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4"
  data-oid="{{ oid }}"
  data-survey="{{ survey_id }}"
  {#
    Two flavors of URL template attached:
      - `data-url-template-{type}`: primary-survey URL with the OID baked in,
        only `__IDENT__` left to substitute. Used for in-survey clicks (the
        common case) and for the picker dropdown.
      - `data-url-template-{type}-{survey}`: per-survey URL with BOTH
        `__OID__` and `__IDENT__` to substitute. Used when a click lands on
        a cross-survey LC point — the JS pulls the matched OID off the LC
        chart's `$lcXOid` and renders the right survey's stamp service.
  #}
  {% for t in ctx.stamp_types %}
    data-url-template-{{ t }}="{{ ctx.stamp_url_templates[t] }}"
  {% endfor %}
  {% for s, by_type in ctx.stamp_url_templates_by_survey.items() %}
    {% for t in ctx.stamp_types %}
    data-url-template-{{ t }}-{{ s }}="{{ by_type[t] }}"
    {% endfor %}
  {% endfor %}
>
  <div class="tw-flex tw-items-center tw-justify-between tw-mb-3 tw-gap-3">
    {% from "_panel_help.html.jinja" import panel_help %}
    {% call panel_help("Stamps") %}
      <div class="tw-font-semibold tw-mb-1">What you're looking at</div>
      <ul class="tw-space-y-0.5 tw-mb-3 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li><strong class="tw-text-text-primary">Science</strong> — the raw survey image at this detection's epoch</li>
        <li><strong class="tw-text-text-primary">Template</strong> — the reference image subtracted from the science frame</li>
        <li><strong class="tw-text-text-primary">Difference</strong> — science − template (where the alert came from)</li>
      </ul>
      <div class="tw-font-semibold tw-mb-1">Survey specifics</div>
      <ul class="tw-space-y-0.5 tw-mb-3 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li>LSST: FITS cutouts parsed in-browser (asinh stretch, WCS rotated so north is up)</li>
        <li>ZTF: PNG thumbnails from the ALeRCE stamp service</li>
        <li>Top-right arrows on each stamp point North / East</li>
      </ul>
      <div class="tw-font-semibold tw-mb-1">Controls</div>
      <ul class="tw-space-y-0.5 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li>Dropdown: switch to a different epoch — MJD + band listed</li>
        <li><span class="mono">−</span> / <span class="mono">+</span> / reset: zoom all three stamps in sync, centred on the object</li>
        <li>Clicking a point in the light curve or position residuals panel jumps to that epoch here</li>
      </ul>
    {% endcall %}
    {% if ctx.detections %}
      {# Zoom controls operate on all three stamps simultaneously. The object
         sits at the centre of each stamp (survey-cutout contract), so a
         pure scale-about-centre keeps it anchored. Handlers live in stamps.js. #}
      <div class="tw-flex tw-items-center tw-gap-1">
        <button
          type="button"
          class="stamps-zoom-btn tw-px-2 tw-py-1 tw-text-sm tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
          title="Zoom out"
          onclick="window.zoomStamps && window.zoomStamps(this, 1/1.25)"
        >−</button>
        <button
          type="button"
          class="stamps-zoom-reset tw-px-2 tw-py-1 tw-text-xs tw-text-text-muted hover:tw-text-text-primary tw-border tw-border-border tw-rounded mono"
          title="Reset zoom"
          onclick="window.zoomStamps && window.zoomStamps(this, 'reset')"
        >1.00×</button>
        <button
          type="button"
          class="stamps-zoom-btn tw-px-2 tw-py-1 tw-text-sm tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
          title="Zoom in"
          onclick="window.zoomStamps && window.zoomStamps(this, 1.25)"
        >+</button>
      </div>
      <select
        class="tw-bg-bg-secondary tw-border tw-border-border tw-rounded tw-px-2 tw-py-1 tw-text-xs tw-text-text-primary"
        name="identifier"
        onchange="window.updateStampsForIdentifier && window.updateStampsForIdentifier(this.value)"
      >
        {#
          Each option labels the band with its survey ("LSST g", "ZTF r")
          so the band letter is unambiguous when a cross-survey overlay is
          loaded — `g` means different things on the two telescopes.
          Picker entries today come from the primary survey only, but the
          per-row tagging is forward-compatible with a future cross-survey
          picker extension.
        #}
        {% for d in ctx.detections %}
          <option
            value="{{ d.identifier }}"
            {% if ctx.selected and d.identifier == ctx.selected.identifier %}selected{% endif %}
          >
            MJD {{ "%.3f"|format(d.mjd) }}{% if d.band %} · {{ survey_id|upper }} {{ d.band }}{% endif %}
          </option>
        {% endfor %}
      </select>
    {% endif %}
  </div>

  {% if ctx.selected %}
    <div class="tw-grid tw-grid-cols-3 tw-gap-3">
      {% for t in ctx.stamp_types %}
        <div class="tw-flex tw-flex-col tw-items-center tw-gap-1">
          <div class="tw-relative tw-w-full tw-aspect-square tw-bg-bg-secondary tw-rounded tw-overflow-hidden">
            <canvas
              class="stamp-canvas tw-w-full tw-h-full tw-block"
              data-stamp-url="{{ ctx.stamp_urls[t] }}"
              data-stamp-type="{{ t }}"
              width="180" height="180"
            ></canvas>
            <div class="stamp-loading tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-text-xs tw-text-text-muted">
              loading…
            </div>
            <div class="stamp-compass tw-absolute tw-top-1 tw-right-1 tw-text-xs tw-text-text-secondary tw-font-mono"></div>
          </div>
          <div class="tw-text-xs tw-text-text-muted tw-capitalize">{{ t }}</div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">
      No detections with stamps.
    </div>
  {% endif %}
</div>
