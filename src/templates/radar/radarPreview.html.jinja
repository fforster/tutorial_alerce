{#
  Radar-plot panel — rendered by /htmx/probability.
  ctx has {groups: [{key, classifier_name, classifier_version, classes:[{class_name, probability, is_max}]}], default_key}.
  We embed every classifier group as JSON on the canvas so the picker can
  swap between them without another server round trip.
#}
<div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4">
  <div class="tw-flex tw-flex-col tw-items-start tw-gap-2 tw-mb-3">
    {% from "_panel_help.html.jinja" import panel_help %}
    {% call panel_help("Probabilities") %}
      <div class="tw-font-semibold tw-mb-1">What's plotted</div>
      <p class="tw-mb-3 tw-text-text-secondary">Radar chart of class probabilities from the selected classifier. Each axis is a class; the polygon spans 0 to 1. The top class is highlighted so the dominant prediction reads at a glance.</p>
      <div class="tw-font-semibold tw-mb-1">Classifier picker</div>
      <p class="tw-mb-3 tw-text-text-secondary">The dropdown lists every classifier that has scored this object (e.g. stamp vs. light-curve classifiers, or different versions). Switching is client-side — all classifier groups arrive with the panel.</p>
      <div class="tw-font-semibold tw-mb-1">Reading the polygon</div>
      <ul class="tw-space-y-0.5 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li>A single long spike = confident classification</li>
        <li>Multiple comparable lobes = ambiguous object</li>
        <li>Hover an axis to see the exact probability</li>
      </ul>
    {% endcall %}
    {% if ctx.groups %}
      {# Dropdown sits below the title so it gets the full row; long classifier
         keys are allowed to overflow the panel's right edge rather than wrap. #}
      <select
        class="radar-classifier-select tw-max-w-none tw-bg-bg-secondary tw-border tw-border-border tw-rounded tw-px-2 tw-py-1 tw-text-xs tw-text-text-primary"
        data-target="radar-canvas-{{ oid }}"
      >
        {% for g in ctx.groups %}
          <option
            value="{{ g.key }}"
            {% if g.key == ctx.default_key %}selected{% endif %}
          >{{ g.key }}</option>
        {% endfor %}
      </select>
    {% endif %}
  </div>

  {% if ctx.groups %}
    <div class="tw-relative tw-w-full tw-aspect-square">
      <canvas
        id="radar-canvas-{{ oid }}"
        class="radar-canvas"
        data-probs='{{ ctx|tojson_compact }}'
      ></canvas>
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">No probabilities.</div>
  {% endif %}
</div>
