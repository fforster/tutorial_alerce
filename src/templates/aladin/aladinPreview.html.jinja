{#
  Aladin panel — rendered by /htmx/aladin. The server emits the empty target
  div and the RA/Dec; client JS (static/js/aladin.js) probes HiPS coverage
  (DESI → PanSTARRS → SkyMapper → DSS fallback) and boots Aladin Lite on it.

  Aladin Lite v3 is loaded from CDS CDN the first time an aladin panel is
  rendered — it's a megabyte of JS and we don't want it on every page view.
#}
<div id="aladin-panel" class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-h-full tw-flex tw-flex-col">
  <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
    {% from "_panel_help.html.jinja" import panel_help %}
    {% call panel_help("Sky view", side="right") %}
      <div class="tw-font-semibold tw-mb-1">What's shown</div>
      <p class="tw-mb-3 tw-text-text-secondary">Aladin Lite sky viewer centred on the object, backed by HiPS imagery (DESI → PanSTARRS → SkyMapper → DSS fallback depending on coverage).</p>
      <div class="tw-font-semibold tw-mb-1">Navigation</div>
      <ul class="tw-space-y-0.5 tw-mb-3 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li>Pan: drag</li>
        <li>Zoom: scroll wheel or pinch</li>
        <li>Imagery / overlay picker: toolbar at top-right of the viewer</li>
      </ul>
      <div class="tw-font-semibold tw-mb-1">Host-galaxy spec-z</div>
      <p class="tw-text-text-secondary">Coloured chips mark VizieR catalog sources (DESI DR1, SDSS DR16, 6dFGS, GAMA, 2MRS, WiggleZ, zCOSMOS, VIPERS PDR2, OzDES DR1). Click a chip to populate the <em>z</em> input in the light-curve panel — useful for absolute-magnitude mode.</p>
    {% endcall %}
    <div id="aladin-legend-{{ oid }}" class="tw-text-xs tw-text-text-muted tw-font-mono"></div>
  </div>

  {#
    Host fills the remaining vertical space so the panel matches the
    stamps-panel height in this row. Aladin Lite picks up the host's
    runtime size, so dropping the fixed 1:1 aspect doesn't break the
    viewer — it just renders at whatever height the row ends up at.
  #}
  {% if ra is not none and dec is not none %}
    <div
      class="aladin-host tw-relative tw-w-full tw-flex-1 tw-min-h-0 tw-bg-bg-secondary tw-rounded tw-overflow-hidden"
      data-ra="{{ ra }}"
      data-dec="{{ dec }}"
      data-oid="{{ oid }}"
      data-legend-id="aladin-legend-{{ oid }}"
    >
      <div class="aladin-loading tw-absolute tw-inset-0 tw-flex tw-items-center tw-justify-center tw-text-xs tw-text-text-muted">
        loading sky view…
      </div>
    </div>
    <div class="tw-text-xs tw-text-text-muted tw-mt-2 tw-font-mono">
      RA {{ "%.5f"|format(ra) }}° · Dec {{ "%.5f"|format(dec) }}°
    </div>
  {% else %}
    <div class="tw-text-xs tw-text-text-muted tw-py-6 tw-text-center">
      No coordinates for this object.
    </div>
  {% endif %}
</div>
