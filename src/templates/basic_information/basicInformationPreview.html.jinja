{#
  Basic Information panel — populated by /htmx/object_information.
  Expects `info` (shape_object_info output) and `survey_id`.
#}
<div id="basic-info" class="tw-h-full tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-sm">
  <div class="tw-mb-3">
    {% from "_panel_help.html.jinja" import panel_help %}
    {% call panel_help("Basic Information") %}
      <div class="tw-font-semibold tw-mb-1">Fields</div>
      <ul class="tw-space-y-0.5 tw-mb-3 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li><strong class="tw-text-text-primary">RA / Dec</strong> — mean object position</li>
        <li><strong class="tw-text-text-primary">First / Last MJD</strong> — time span of detections (Δ MJD is the extent)</li>
        <li><strong class="tw-text-text-primary">N det / N non-det</strong> — detection and non-detection counts</li>
        <li><strong class="tw-text-text-primary">N forced</strong> — LSST forced-photometry count (when available)</li>
        <li><strong class="tw-text-text-primary">Corrected / Stellar</strong> — ZTF only: whether host-galaxy correction was applied, and a stellarity flag</li>
      </ul>
      <div class="tw-font-semibold tw-mb-1">Coord controls</div>
      <ul class="tw-space-y-0.5 tw-mb-3 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li><strong class="tw-text-text-primary">⇄ (left of the RA, Dec label)</strong> — cycles the row through Equatorial (RA, Dec), Galactic (ℓ, b), and J2000 Ecliptic (λ, β); the label updates so the current system is always readable</li>
        <li><strong class="tw-text-text-primary">HMS / Deg</strong> — switches RA/Dec between decimal degrees and sexagesimal; Equatorial only</li>
        <li><strong class="tw-text-text-primary">Copy</strong> — copies the currently-displayed pair to the clipboard (✓ / ✗ flashes next to the button)</li>
      </ul>
      <div class="tw-font-semibold tw-mb-1">TNS</div>
      <p class="tw-text-text-secondary tw-mb-3">When a Transient Name Server object matches the cone-search on this object's position, the panel shows its TNS class, name, and reported redshift. Follow the name/TNS link for discovery and classification reporters. (Sourced via ALeRCE's TNS bridge.)</p>
      <div class="tw-font-semibold tw-mb-1">Actions</div>
      <ul class="tw-space-y-0.5 tw-list-disc tw-list-inside tw-text-text-secondary">
        <li><strong class="tw-text-text-primary">Show features</strong> — opens the full ALeRCE feature table for this object (ZTF only; LSST has no features endpoint yet)</li>
        <li><strong class="tw-text-text-primary">Other archives ▾</strong> — links to external catalogs and services (ALeRCE, NED, SIMBAD, TNS, …) pre-populated with this object's coordinates</li>
      </ul>
    {% endcall %}
    <div class="mono tw-text-base tw-mt-1">{{ info.oid }}</div>
    <div class="tw-text-text-muted tw-text-xs tw-mt-1">Survey: {{ survey_id }}</div>
    {#
      Cross-survey match placeholder. Hidden until the deferred LC fetch
      (/htmx/lc_xsurvey) finds a counterpart and the inline `lcSetCrossSurvey`
      call populates it via the data-* hooks below. data-oid is stamped so the
      JS knows which detail view this row belongs to (avoids cross-talk if a
      stale fragment lingers in the DOM during a swap).
    #}
    <div
      id="basic-info-xsurvey"
      class="tw-text-xs tw-mt-1 tw-hidden"
      data-oid="{{ info.oid }}"
      data-primary-survey="{{ survey_id }}"
    ></div>
  </div>

  {#
    Single-column layout, ordered top → bottom: combined RA/Dec row, then the
    time fields (First/Last MJD at 6 decimals, Δ MJD with its human/days
    toggle), then ZTF-only flags (Corrected/Stellar), then the detection
    counts at the bottom.

    3-column grid (label | value | controls). RA/Dec lives on one row with
    both values stacked horizontally in a single `<dd>`; the other rows use
    `tw-col-span-2` on the dd so the value extends into the controls column
    when no toggle button is rendered. The controls column is `auto` so it
    shrinks to fit the longest button.
  #}
  <dl class="tw-grid tw-grid-cols-[auto_auto_auto] tw-gap-x-2 tw-gap-y-1 tw-text-xs tw-items-center">
    {#
      Combined RA, Dec row. A single ⇄ icon-button to the left cycles the
      system (Eq → Gal → Ecl) and updates the label pair in-place. The
      two values are independent `.coord-value` spans (so the existing JS
      that iterates them keeps working unchanged) joined by a literal ", "
      text node that stays put across textContent updates on each span.
    #}
    <dt class="tw-flex tw-items-center tw-gap-1">
      <button
        type="button"
        class="coord-system-toggle tw-px-1 tw-text-[10px] tw-leading-none tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded"
        aria-label="Cycle coordinate system (Equatorial, Galactic, Ecliptic)"
        title="Cycle coord system: RA/Dec ↔ ℓ/b ↔ λ/β"
      >⇄</button>
      <span class="coord-label-pair tw-text-text-secondary">RA, Dec</span>
    </dt>
    <dd class="mono tw-whitespace-nowrap">
      <span class="coord-value"
            data-axis="ra"
            data-deg="{% if info.ra is not none %}{{ '%.5f'|format(info.ra) }}{% endif %}"
            data-sex="{{ info.ra_hms or '' }}"
            data-gal="{% if info.l_gal is not none %}{{ '%.5f'|format(info.l_gal) }}{% endif %}"
            data-ecl="{% if info.lambda_ecl is not none %}{{ '%.5f'|format(info.lambda_ecl) }}{% endif %}"
      >{% if info.ra is not none %}{{ "%.5f"|format(info.ra) }}{% else %}-{% endif %}</span>,
      <span class="coord-value"
            data-axis="dec"
            data-deg="{% if info.dec is not none %}{{ '%.5f'|format(info.dec) }}{% endif %}"
            data-sex="{{ info.dec_dms or '' }}"
            data-gal="{% if info.b_gal is not none %}{{ '%.5f'|format(info.b_gal) }}{% endif %}"
            data-ecl="{% if info.beta_ecl is not none %}{{ '%.5f'|format(info.beta_ecl) }}{% endif %}"
      >{% if info.dec is not none %}{{ "%.5f"|format(info.dec) }}{% else %}-{% endif %}</span>
    </dd>
    {% if info.ra is not none and info.dec is not none %}
    {#
      Controls: HMS/Deg toggle + copy icon. They sit on the same row as
      the merged RA/Dec value, mirroring how the previous two-row layout
      attached each control to its row.
    #}
    <div class="tw-justify-self-start tw-flex tw-items-center tw-gap-1">
      <button
        type="button"
        class="coord-format-toggle tw-px-1 tw-text-[10px] tw-leading-none tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded"
        data-mode="deg"
        title="Toggle RA/Dec between decimal degrees and sexagesimal (HH:MM:SS ±DD:MM:SS). Equatorial only."
        aria-pressed="false"
      >HMS</button>
      <button
        type="button"
        class="coord-copy-btn tw-p-0.5 tw-leading-none tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded"
        title="Copy 'RA Dec' (in the currently-displayed format) to the clipboard."
        aria-label="Copy RA Dec"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
      <span class="coord-copy-msg tw-w-3 tw-text-xs tw-leading-none" role="status" aria-live="polite"></span>
    </div>
    {% else %}
    <span></span>
    {% endif %}

    <dt class="tw-text-text-secondary">First MJD</dt>
    <dd class="mono tw-col-span-2">{% if info.firstmjd is not none %}{{ "%.6f"|format(info.firstmjd) }}{% else %}-{% endif %}</dd>

    <dt class="tw-text-text-secondary">Last MJD</dt>
    <dd class="mono tw-col-span-2">{% if info.lastmjd is not none %}{{ "%.6f"|format(info.lastmjd) }}{% else %}-{% endif %}</dd>

    <dt class="tw-text-text-secondary">Δ MJD</dt>
    {#
      Two displays of the same duration: the human breakdown (default) and
      a raw 6-decimal day count. Both strings are precomputed and stashed
      on data-* attrs so the toggle is pure DOM — no recompute on click.
    #}
    <dd class="mono delta-mjd-value"
        data-human="{{ info.delta_mjd_human or '' }}"
        data-days="{% if info.delta_mjd is not none %}{{ '%.6f'|format(info.delta_mjd) }}{% endif %}">
      {% if info.delta_mjd_human %}{{ info.delta_mjd_human }}{% else %}-{% endif %}
    </dd>
    {% if info.delta_mjd is not none %}
    <button
      type="button"
      class="delta-mjd-toggle tw-justify-self-start tw-px-1 tw-text-[10px] tw-leading-none tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded"
      data-mode="human"
      title="Toggle Δ MJD between the human breakdown (yr/d/h/m/s) and days with 6 decimals."
      aria-pressed="false"
    >Days</button>
    {% else %}
    <span></span>
    {% endif %}

    {% if survey_id == 'ztf' %}
    <dt class="tw-text-text-secondary">Corrected</dt>
    <dd class="mono tw-col-span-2">{% if info.corrected is not none %}{{ info.corrected }}{% else %}-{% endif %}</dd>

    <dt class="tw-text-text-secondary">Stellar</dt>
    <dd class="mono tw-col-span-2">{% if info.stellar is not none %}{{ info.stellar }}{% else %}-{% endif %}</dd>
    {% endif %}

    {# Detection counts sit at the bottom of the table. #}
    <dt class="tw-text-text-secondary">N det</dt>
    <dd class="mono tw-col-span-2">{% if info.n_det is not none %}{{ info.n_det }}{% else %}-{% endif %}</dd>

    <dt class="tw-text-text-secondary">N non-det</dt>
    <dd class="mono tw-col-span-2">{% if info.n_non_det is not none %}{{ info.n_non_det }}{% else %}-{% endif %}</dd>

    {% if info.n_forced is not none %}
    <dt class="tw-text-text-secondary">N forced</dt>
    <dd class="mono tw-col-span-2">{{ info.n_forced }}</dd>
    {% endif %}
  </dl>

  {#
    Deferred TNS placeholder. The /htmx/tns_lookup fragment fills this div
    via innerHTML (the response includes a styled `<div class="tns-block">`
    when there's a match, or an empty body when there isn't — keeping the
    panel uncluttered). It also runs an inline script that auto-populates
    `#lc-redshift-{oid}` if a positive redshift is reported AND the LC
    panel is in the DOM (TNS is strictly additive: never blocks, never
    invents data).

    The fetch only fires when ra/dec are known — LSST objects without
    coords skip TNS entirely, matching the prior server-side behavior.
  #}
  {% if info.ra is not none and info.dec is not none %}
  <div
    id="basic-info-tns"
    hx-get="{{ API_URL }}/htmx/tns_lookup?oid={{ info.oid }}&ra={{ info.ra }}&dec={{ info.dec }}"
    hx-trigger="load"
    hx-swap="innerHTML"
  ></div>
  {% endif %}

  {#
    Bottom action row: Show features + Other archives, with an Airmass
    button on its own row below. The coord-system cycler used to live
    here as an "Eq" button — it's now folded into the RA/Dec labels
    above, so the row only renders when features, archives, or coords
    (which gate the Airmass button) are relevant.
  #}
  {% set has_coords = info.ra is not none and info.dec is not none %}
  {% if has_features or info.archives or has_coords %}
    <div class="tw-mt-3 tw-pt-3 tw-border-t tw-border-border tw-flex tw-flex-col tw-gap-2">
    <div class="tw-flex tw-items-center tw-gap-2 tw-flex-wrap">
      {% if has_features %}
      {#
        hx-indicator="#features-loading" reveals the spinner next to the
        button while the request is in flight (≥1 s on cold cache). Without
        feedback the user would double-click, which `hx-disabled-elt="this"`
        also guards against. `role="status"` + `aria-live="polite"` makes
        the spinner audible to screen readers.
      #}
      <button
        type="button"
        class="tw-px-2 tw-py-1 tw-text-xs tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-60 disabled:tw-cursor-wait"
        hx-get="{{ API_URL }}/htmx/features?oid={{ info.oid }}&survey_id={{ survey_id }}"
        hx-target="#features-modal"
        hx-swap="innerHTML"
        hx-indicator="#features-loading"
        hx-disabled-elt="this"
        title="Show the full ALeRCE feature table for this object."
      >Show features</button>
      {#
        `htmx-indicator-scoped` instead of the built-in `htmx-indicator`:
        the default class reacts to any ancestor with `.htmx-request`, so
        Back-to-results (which puts `.htmx-request` on `#results-slot`) was
        lighting up this spinner even though the Show-features button
        didn't fire. The scoped variant only lights up when htmx adds
        `.htmx-request` directly to this element via hx-indicator.
      #}
      <span
        id="features-loading"
        class="htmx-indicator-scoped tw-text-xs tw-text-text-muted tw-whitespace-nowrap"
        role="status"
        aria-live="polite"
      >
        <span class="tw-inline-block tw-animate-spin">◐</span> Loading features…
      </span>
      {% endif %}
      {% if info.archives %}
      {#
        Dropdown opens upward (`tw-bottom-full`) because this row sits at
        the bottom of the panel — opening downward would overflow the card.
      #}
      <details class="tw-relative">
        <summary class="tw-cursor-pointer tw-px-2 tw-py-1 tw-text-xs tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded">
          Other archives ▾
        </summary>
        <div class="tw-absolute tw-left-0 tw-bottom-full tw-mb-1 tw-bg-bg-secondary tw-border tw-border-border tw-rounded tw-p-2 tw-min-w-48 tw-z-10 tw-shadow-lg">
          {% for link in info.archives %}
            <a href="{{ link.url }}" target="_blank" rel="noopener"
               class="tw-block tw-px-2 tw-py-1 tw-text-xs tw-text-text-primary hover:tw-bg-bg-tertiary tw-rounded">
              {{ link.name }}
            </a>
          {% endfor %}
        </div>
      </details>
      {% endif %}
    </div>
    {#
      Airmass row — sits on its own line beneath "Show features" so the
      button is visible even when the action row above wraps to two lines.
      Toggles the airmass overlay panel that lives in the same grid cell
      as the position-residuals plot. Mutually exclusive with the
      periodogram panel; coordinates are required (no point computing
      airmass without an object position).
    #}
    {% if has_coords %}
    <div class="tw-flex tw-items-center tw-gap-2 tw-flex-wrap">
      <button
        type="button"
        class="basic-info-airmass-btn tw-px-2 tw-py-1 tw-text-xs tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded"
        onclick="window.toggleAirmassPanel && window.toggleAirmassPanel('{{ info.oid }}', {{ info.ra }}, {{ info.dec }})"
        title="Show this object's airmass evolution over a UTC night for a chosen observatory (replaces the position-residuals panel)."
        aria-pressed="false"
      >Airmass</button>
    </div>
    {% endif %}
    </div>
  {% endif %}
</div>

<script>
(function () {
  // Re-runs on every object_information swap because the <script> is part
  // of the fragment. IIFE-scoped so each run has its own refs; no globals.
  const root = document.getElementById("basic-info");
  if (!root) return;
  const toggle = root.querySelector(".coord-format-toggle");
  const systemToggles = root.querySelectorAll(".coord-system-toggle");
  const copyBtn = root.querySelector(".coord-copy-btn");
  const msg = root.querySelector(".coord-copy-msg");
  const values = root.querySelectorAll(".coord-value");
  const labelPair = root.querySelector(".coord-label-pair");
  if (!values.length) return;

  // Combined "RA, Dec" / "ℓ, b" / "λ, β" pair label. The row stays
  // self-documenting when the system changes; the dedicated ⇄ button is
  // the click target, so the label text itself is always readable.
  const SYSTEM_LABEL_PAIR = {
    eq:  "RA, Dec",
    gal: "ℓ, b",
    ecl: "λ, β",
  };
  const SYSTEM_CYCLE = ["eq", "gal", "ecl"];

  function currentSystem() {
    // State lives on the panel root so both label buttons read/write the
    // same value — click either one and both update.
    return root.dataset.coordSystem || "eq";
  }

  function currentFormat() {
    // Default "deg" — if the toggle button isn't rendered (only one coord
    // available, say), we still want the cells to fall back to degrees.
    return toggle ? toggle.dataset.mode : "deg";
  }

  function apply() {
    const system = currentSystem();
    const format = currentFormat();
    values.forEach((cell) => {
      let next;
      if (system === "gal") next = cell.dataset.gal;
      else if (system === "ecl") next = cell.dataset.ecl;
      else next = format === "sex" ? cell.dataset.sex : cell.dataset.deg;
      // Blank data-sex (e.g. dec_dms was None) → fall back to the degrees
      // form rather than showing an empty cell. Same guard for gal/ecl.
      cell.textContent = next || cell.dataset.deg || "-";
    });
    if (labelPair) labelPair.textContent = SYSTEM_LABEL_PAIR[system] || labelPair.textContent;
    if (toggle) {
      // Sexagesimal doesn't apply to galactic / ecliptic — make the button
      // unclickable + invisible so users aren't tempted to click a no-op.
      // `visibility: hidden` (not `display: none`) keeps the grid cell so
      // its siblings don't reflow into the gap.
      const hide = system !== "eq";
      toggle.style.visibility = hide ? "hidden" : "";
      toggle.disabled = hide;
      toggle.textContent = format === "deg" ? "HMS" : "Deg";
      toggle.setAttribute("aria-pressed", format === "sex" ? "true" : "false");
    }
  }

  if (toggle) {
    toggle.addEventListener("click", () => {
      toggle.dataset.mode = currentFormat() === "deg" ? "sex" : "deg";
      apply();
    });
  }
  // Both ⇄ buttons share state on `root.dataset.coordSystem`, so binding the
  // same handler to each keeps them synchronized — clicking either cycles
  // both rows together.
  systemToggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = SYSTEM_CYCLE.indexOf(currentSystem());
      root.dataset.coordSystem = SYSTEM_CYCLE[(idx + 1) % SYSTEM_CYCLE.length];
      apply();
    });
  });
  apply();

  // Δ MJD toggle: swap between the human breakdown and 6-decimal days. The
  // two strings are precomputed on data-human / data-days; the button label
  // shows the *other* format (clicking "Days" gives you days, then becomes
  // "Human" to switch back). Falls back gracefully if either string is
  // missing — should only happen when delta_mjd itself is None, in which
  // case the button isn't rendered anyway.
  const deltaCell = root.querySelector(".delta-mjd-value");
  const deltaToggle = root.querySelector(".delta-mjd-toggle");
  if (deltaCell && deltaToggle) {
    const human = deltaCell.dataset.human || "-";
    const days = deltaCell.dataset.days ? `${deltaCell.dataset.days} d` : "-";
    deltaToggle.addEventListener("click", () => {
      const next = deltaToggle.dataset.mode === "human" ? "days" : "human";
      deltaToggle.dataset.mode = next;
      deltaCell.textContent = next === "human" ? human : days;
      deltaToggle.textContent = next === "human" ? "Days" : "Human";
      deltaToggle.setAttribute("aria-pressed", next === "days" ? "true" : "false");
    });
  }

  if (copyBtn) {
    copyBtn.addEventListener("click", async () => {
      // Copies the currently-displayed format so "what you see is what you
      // paste" — don't second-guess the user's choice by re-formatting.
      const ra = root.querySelector('.coord-value[data-axis="ra"]');
      const dec = root.querySelector('.coord-value[data-axis="dec"]');
      const text = `${(ra?.textContent || "").trim()} ${(dec?.textContent || "").trim()}`.trim();
      if (!text) return;
      function flash(ok) {
        if (!msg) return;
        // Tick glyph instead of text — previous "Copied"/"Copy failed"
        // labels overflowed onto the coord string. Green/red is set inline
        // so we don't depend on Tailwind palette classes being compiled.
        const tick = ok ? "✓" : "✗";
        msg.textContent = tick;
        msg.style.color = ok ? "#4ade80" : "#f87171";
        msg.setAttribute("aria-label", ok ? "Copied" : "Copy failed");
        // Short confirmation; long enough to catch the eye, short enough not
        // to linger across a panel swap.
        setTimeout(() => {
          if (msg.textContent === tick) {
            msg.textContent = "";
            msg.style.color = "";
            msg.removeAttribute("aria-label");
          }
        }, 1500);
      }
      try {
        await navigator.clipboard.writeText(text);
        flash(true);
      } catch (_e) {
        // Fallback for contexts where the Clipboard API isn't available
        // (older browsers, insecure origins): use the textarea + execCommand
        // trick so the button still works instead of silently failing.
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.setAttribute("readonly", "");
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        let ok = false;
        try { ok = document.execCommand("copy"); } catch (_e2) {}
        document.body.removeChild(ta);
        flash(ok);
      }
    });
  }
})();
</script>
