{#
  Object detail container — swapped into #results-slot when a row is clicked.

  Layout (search sidebar sits to the left of this, outside the container):
    4-column grid.
    Row 1: basic-information (1 col) | light curve (2 cols) | position residuals (1 col).
    Row 2: radar plot (1 col) | stamps (2 cols) | Aladin (1 col).
#}
<div
  id="object-detail"
  class="tw-flex tw-flex-col tw-gap-3"
  data-oid="{{ oid }}"
  data-survey-id="{{ survey_id }}"
  {% if classifier %}data-classifier="{{ classifier }}"{% endif %}
>

  <div class="tw-flex tw-items-center tw-gap-2">
    <button
      type="button"
      class="tw-px-3 tw-py-1 tw-text-xs tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded"
      hx-get="{{ API_URL }}/htmx/list_objects"
      hx-target="#results-slot"
      hx-swap="innerHTML"
      hx-indicator="#results-loading"
      hx-vals='js:{...send_form_Data()}'
    >← Back to results</button>
    <div class="tw-text-xs tw-text-text-muted">{{ survey_id|upper }} · {{ oid }}</div>
    {# Prev/next arrows walk through the current page of results; when the
       current OID is at the edge they hop to the previous/next page and pick
       the appropriate sibling. Keyboard ArrowLeft/ArrowRight mirror them.
       Hidden by default — object_nav.js reveals them iff nav state exists. #}
    <div id="object-nav" class="tw-ml-auto tw-hidden tw-items-center tw-gap-2">
      <button
        type="button"
        id="object-nav-prev"
        class="tw-px-2 tw-py-1 tw-text-sm tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
        title="Previous object (←)"
        onclick="navObject('prev')"
      >←</button>
      {# Position indicator — "3/20 · page 2" — populated by object_nav.js. #}
      <span id="object-nav-position" class="tw-text-xs tw-text-text-muted mono"></span>
      <button
        type="button"
        id="object-nav-next"
        class="tw-px-2 tw-py-1 tw-text-sm tw-text-accent hover:tw-text-text-primary tw-border tw-border-border tw-rounded disabled:tw-opacity-30 disabled:tw-cursor-not-allowed"
        title="Next object (→)"
        onclick="navObject('next')"
      >→</button>
    </div>
  </div>

  <div class="tw-grid tw-grid-cols-4 tw-gap-3">
    <div
      id="basic-info-slot"
      class="tw-col-span-1"
      hx-get="{{ API_URL }}/htmx/object_information?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-text-xs tw-text-text-muted tw-p-4">Loading basic information…</div>
    </div>
    <div
      id="lightcurve-slot"
      class="tw-col-span-2"
      hx-get="{{ API_URL }}/htmx/lightcurve?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading light curve…
      </div>
    </div>
    <div
      id="coord-residuals-slot"
      class="tw-col-span-1"
      hx-get="{{ API_URL }}/htmx/coord_residuals?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading position residuals…
      </div>
    </div>

    <div
      id="radar-slot"
      class="tw-col-span-1"
      hx-get="{{ API_URL }}/htmx/probability?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading probabilities…
      </div>
    </div>
    <div
      id="stamps-slot"
      class="tw-col-span-2"
      hx-get="{{ API_URL }}/htmx/stamps?oid={{ oid }}&survey_id={{ survey_id }}{% if identifier %}&identifier={{ identifier|urlencode }}{% endif %}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading stamps…
      </div>
    </div>
    <div
      id="aladin-slot"
      class="tw-col-span-1"
      hx-get="{{ API_URL }}/htmx/aladin?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading sky view…
      </div>
    </div>
  </div>

</div>
