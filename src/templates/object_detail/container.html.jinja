{#
  Object detail container — swapped into #results-slot when a row is clicked.

  Layout (search sidebar sits to the left of this, outside the container):
    4-column grid with un-equal columns. Side panels (basic-info,
    position-residuals/periodogram/airmass, radar, aladin) sit in
    1-fr columns; the centre panels (light curve, stamps) span two
    1.3-fr columns each. The 1 : 1.3 : 1.3 : 1 ratio nudges the side
    panels toward a square aspect (the row height is ~23rem) and frees
    the freed pixels for the wider LC + stamps. Inline
    `grid-template-columns` so it works without depending on whether
    Tailwind's JIT picked up the arbitrary `[…fr]` class.
    Row 1: basic-information | light curve (2 cols) | position residuals.
    Row 2: radar plot | stamps (2 cols) | Aladin.
#}
<div
  id="object-detail"
  class="tw-flex tw-flex-col tw-gap-3"
  data-oid="{{ oid }}"
  data-survey-id="{{ survey_id }}"
  {% if classifier %}data-classifier="{{ classifier }}"{% endif %}
>

  {#
    Nav row (Back / OID dots / prev-next arrows + position) used to live
    here as the first child. It was promoted to the global header in
    index.html.jinja (#detail-nav-bar) so the detail panels can use the
    full vertical space. object_nav.js shows/hides the bar based on
    whether `#object-detail` (this element) is in the DOM.
  #}
  {#
    Each side panel carries `aspect-ratio: 1/1` inline so its height
    follows its column width — the grid then takes both row heights
    from the (identical) side-panel widths, and the LC + stamps
    panels (col-span-2) stretch to match. Result: both rows have the
    same height, side panels are square. Inline style so a stale
    Tailwind build can't drop the rule.
  #}
  {% set side_square = "aspect-ratio: 1 / 1;" %}
  <div class="tw-grid tw-gap-3" style="grid-template-columns: 1fr 1.3fr 1.3fr 1fr;">
    <div
      id="basic-info-slot"
      class="tw-col-span-1 tw-overflow-auto tw-min-h-0"
      style="{{ side_square }}"
      hx-get="{{ API_URL }}/htmx/object_information?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-text-xs tw-text-text-muted tw-p-4">Loading basic information…</div>
    </div>
    <div
      id="lightcurve-slot"
      class="tw-col-span-2"
      hx-get="{{ API_URL }}/htmx/lightcurve?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading light curve…
      </div>
    </div>
    {#
      Position residuals + periodogram + airmass share the same grid cell.
      Only one is visible at a time; togglePeriodogramPanel and
      toggleAirmassPanel manage the mutual-exclusion (and which button is
      highlighted) via tw-hidden. Periodogram is driven from the LC
      toolbar's Periodogram button; Airmass from the Basic Information
      panel's Airmass button. Panels carry their templates inline so the
      canvas is ready for Chart.js the first time the toggle flips it on.
    #}
    <div
      class="tw-col-span-1 tw-min-h-0 tw-min-w-0"
      style="{{ side_square }}"
    >
      <div
        id="coord-residuals-slot"
        class="tw-h-full"
        hx-get="{{ API_URL }}/htmx/coord_residuals?oid={{ oid }}&survey_id={{ survey_id }}"
        hx-trigger="load"
        hx-swap="innerHTML"
      >
        <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
          Loading position residuals…
        </div>
      </div>
      <div id="periodogram-slot" class="tw-hidden tw-h-full">
        {% include "periodogram/periodogramPreview.html.jinja" %}
      </div>
      <div id="airmass-slot" class="tw-hidden tw-h-full">
        {% include "airmass/airmassPanel.html.jinja" %}
      </div>
    </div>

    <div
      id="radar-slot"
      class="tw-col-span-1 tw-min-h-0"
      style="{{ side_square }}"
      hx-get="{{ API_URL }}/htmx/probability?oid={{ oid }}&survey_id={{ survey_id }}{% if classifier %}&classifier={{ classifier|urlencode }}{% endif %}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading probabilities…
      </div>
    </div>
    <div
      id="stamps-slot"
      class="tw-col-span-2 tw-min-h-0"
      hx-get="{{ API_URL }}/htmx/stamps?oid={{ oid }}&survey_id={{ survey_id }}{% if identifier %}&identifier={{ identifier|urlencode }}{% endif %}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading stamps…
      </div>
    </div>
    <div
      id="aladin-slot"
      class="tw-col-span-1 tw-min-h-0"
      style="{{ side_square }}"
      hx-get="{{ API_URL }}/htmx/aladin?oid={{ oid }}&survey_id={{ survey_id }}"
      hx-trigger="load"
      hx-swap="innerHTML"
    >
      <div class="tw-bg-bg-card tw-border tw-border-border tw-rounded tw-p-4 tw-text-xs tw-text-text-muted">
        Loading sky view…
      </div>
    </div>
  </div>

  {#
    Crossmatch — full-width collapsible at the bottom of the detail page.
    Native <details>/<summary> handles the open/close UI; the fetch fires
    on `load` (not on toggle) so the data is already in the DOM by the
    time the user clicks the summary — no spinner-on-expand wait. The
    panel stays collapsed by default; the only change is that opening
    is instant. catsHTM is the only catalog source for now; future
    xmatch sources will surface as additional cards inside this same
    panel.
  #}
  <div id="crossmatch-slot" class="tw-mt-1">
    <details
      id="crossmatch-details"
      class="tw-bg-bg-card tw-border tw-border-border tw-rounded"
    >
      <summary
        class="tw-cursor-pointer tw-px-4 tw-py-3 tw-text-sm tw-font-medium tw-text-text-primary hover:tw-bg-bg-tertiary tw-flex tw-items-center tw-gap-2"
      >
        <span>Crossmatch &mdash; catsHTM (30&Prime;)</span>
        <span class="tw-text-xs tw-text-text-muted">click to expand</span>
      </summary>
      <div
        id="crossmatch-body"
        class="tw-px-4 tw-pb-4 tw-pt-3 tw-text-xs tw-border-t tw-border-border"
        hx-get="{{ API_URL }}/htmx/crossmatch?oid={{ oid }}&survey_id={{ survey_id }}"
        hx-trigger="load"
        hx-swap="innerHTML"
      >
        <div class="tw-text-text-muted tw-py-3">
          <i class="fa-solid fa-spinner fa-spin tw-mr-1"></i>
          Loading catsHTM crossmatch&hellip;
        </div>
      </div>
    </details>
  </div>

  {# Overlay slot for the "Show features" modal — stays empty until the
     button's hx-get populates it, and the close button clears it again. #}
  <div id="features-modal"></div>

  {# Same pattern for the per-detection AVRO viewer (stamps panel button).
     ZTF-only data, but the slot is unconditional: the LSST path renders
     a "AVRO is ZTF-only" message inside it instead of a separate gate. #}
  <div id="avro-modal"></div>

</div>
